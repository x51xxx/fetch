{
  "name": "@trishchuk/fetch",
  "version": "1.0.1",
  "description": "Fetch API-shaped HTTP client for Node.js with TLS/HTTP2 fingerprint emulation (WHATWG-shaped call signature, URL/Request/Headers inputs, binary/URLSearchParams/Blob bodies; buffered, no streaming yet), backed by a Rust (wreq/hyper/BoringSSL) native addon",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x51xxx/fetch.git"
  },
  "homepage": "https://github.com/x51xxx/fetch#readme",
  "bugs": {
    "url": "https://github.com/x51xxx/fetch/issues"
  },
  "keywords": [
    "fetch",
    "http-client",
    "tls-fingerprint",
    "ja3",
    "ja4",
    "impersonate",
    "curl-impersonate",
    "napi-rs",
    "boringssl"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "napi": {
    "binaryName": "fetch",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.js",
    "binding.d.ts"
  ],
  "scripts": {
    "build": "napi build --platform --release --js binding.js --dts binding.d.ts",
    "build:debug": "napi build --platform --js binding.js --dts binding.d.ts",
    "test": "node --test test/*.test.js",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi pre-publish -t npm",
    "format": "prettier --write . && cargo fmt",
    "format:check": "prettier --check . && cargo fmt -- --check",
    "lint": "eslint . && cargo clippy --all-targets --all-features -- -D warnings"
  },
  "author": "Taras Trishchuk",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^3.7.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  },
  "optionalDependencies": {
    "@trishchuk/fetch-darwin-arm64": "workspace:*",
    "@trishchuk/fetch-darwin-x64": "workspace:*",
    "@trishchuk/fetch-linux-arm64-gnu": "workspace:*",
    "@trishchuk/fetch-linux-arm64-musl": "workspace:*",
    "@trishchuk/fetch-linux-x64-gnu": "workspace:*",
    "@trishchuk/fetch-linux-x64-musl": "workspace:*",
    "@trishchuk/fetch-win32-x64-msvc": "workspace:*"
  }
}
